        {
            "title": "Bloque 2: Realidad Industrial",
            "scenes": [
                {
                    "title": "Amanecer en el Distrito RD",
                    "text": "Despertó con el sabor amargo de la calima industrial. El aire del Distrito RD era una suspensión pesada cargada de residuos. Hoy cumplía diecisiete años.",
                    "assets": [
                        {
                            "id": "distrito_rd_haze_png_1772310841360.png",
                            "zoom": "1.2:1.0",
                            "move": "VER:100:0",
