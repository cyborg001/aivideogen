        {
            "title": "Bloque 8: Final",
            "scenes": [
                {
                    "title": "Orgullo y Sombra",
                    "voice": "es-ES-AlvaroNeural",
                    "text": "Carlos lo observó en silencio, con una mezcla de orgullo y una sombra de advertencia. Darle la [PHO:mótoweiv|Motowave] era darle un sueño. Y en el Distrito RD, los sueños pesaban tanto como el plomo.",
                    "assets": [
                        {
