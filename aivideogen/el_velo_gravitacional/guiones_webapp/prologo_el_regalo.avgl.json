        },
        {
            "title": "Bloque 3: El Taller de Carlos",
            "scenes": [
                {
                    "title": "El Llamado",
                    "voice": "es-DO-EmilioNeural",
                    "text": "—¡Ethan! [PAUSA:0.3] ¡Despierta, mijo! ¡Baja, que tengo algo que mostrarte!",
                    "assets": [
                        {
                            "id": "carlos_taller_steampunk_png_1772310858143.png",
                            "zoom": "1.1:1.2",
                            "move": "HOR:50:60",
