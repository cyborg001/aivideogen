                {
                    "_uId": "s8v2ilb8da",
                    "title": "Risa de Carlos",
                    "text": "[RISA]Carlos sonrió. —¡Jajaja! Dios te bendiga, mijo.[/RISA] —Por un segundo, el peso de la gravedad pareció aliviarse en sus hombros.",
                    "pause": 0.5,
                    "subtitle": "",
                    "voice": null,
                    "audio": null,
                    "pitch": null,
                    "assets": [
                        {
                            "id": "/media/assets/carlos_habla_taller_moto_detras.png",
                            "type": "image",
                            "zoom": "1.0:1.3",
                            "move": "HOR:50:50 + VER:40:60",
