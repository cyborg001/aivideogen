                },
                {
                    "_uId": "s2yyv7yrfe",
                    "title": "Respeto Espiritual",
                    "text": "[PHO]itan|Ethan[/PHO] inclinó la cabeza con respeto. No era una simple costumbre; era una transferencia de momento espiritual, el reconocimiento de que su historia no empezaba con él, sino con los que cruzaron el mar cuando el mundo se rompió.",
                    "pause": 0.5,
                    "subtitle": "",
                    "voice": null,
                    "audio": null,
                    "pitch": null,
                    "assets": [
                        {
                            "id": "/media/assets/ethan_pide_bendicion.png",
                            "type": "image",
                            "zoom": "1.2:1.4",
                            "move": "HOR:50:50",
                            "overlay": null,
                            "fit": false,
                            "video_volume": null,
                            "shake": false,
                            "shake_intensity": 5,
