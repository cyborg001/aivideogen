                    "sfx": []
                },
                {
                    "_uId": "sagevo7sty",
                    "title": "Oasis de Entropía",
                    "text": "El taller de Carlos era un oasis de entropía organizada. Encajado entre estructuras condenadas del viejo mundo, era el único lugar donde [PHO]itan|Ethan[/PHO] sentía que la realidad se podía doblar si tenías las herramientas adecuadas. Su padre siempre lo decía: 'Una pieza de metal no está muerta mientras su resonancia sea pura'. Para Carlos Ramírez, los motores hablaban una lengua de vibraciones que [PHO]itan|Ethan[/PHO] empezaba a descifrar.",
                    "pause": 0.5,
                    "subtitle": "",
                    "voice": null,
                    "audio": null,
                    "pitch": null,
                    "assets": [
                        {
                            "id": "/media/assets/ethan_carlos_regalo_escaleras.png",
                            "type": "image",
                            "zoom": "1.0:1.3",
