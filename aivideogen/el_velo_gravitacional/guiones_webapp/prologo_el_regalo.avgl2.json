        {
            "title": "Block 2: El Taller",
            "scenes": [
                {
                    "_uId": "suzlaqk3or",
                    "title": "El Llamado de Carlos",
                    "text": "[EPICO]—¡[PHO]itan|Ethan[/PHO]! —La voz de Carlos, profunda y con la rugosidad de quien ha inhalado demasiado ozono de soldadura, retumbó desde el taller—. ¡Despierta, mijo! ¡Baja, que tengo algo que mostrarte![/EPICO]",
                    "pause": 0.5,
                    "subtitle": "",
                    "voice": null,
                    "audio": null,
                    "pitch": null,
                    "assets": [
                        {
                            "id": "/media/assets/ethan_despierta.png",
