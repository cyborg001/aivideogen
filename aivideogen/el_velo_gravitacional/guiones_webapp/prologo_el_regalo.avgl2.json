                    "sfx": []
                },
                {
                    "_uId": "s3l1zchooy",
                    "title": "Cion Papi",
                    "text": "—Cion papi. Papi!...[PHO]itan|Ethan[/PHO] se detuvo, sintiendo una fluctuación extraña en su ritmo cardíaco—. ¿Es lo que creo que es?",
                    "pause": 0.5,
                    "subtitle": "",
                    "voice": null,
                    "audio": null,
                    "pitch": null,
                    "assets": [
                        {
                            "id": "ethan_looking_at_gift.png",
