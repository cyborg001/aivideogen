                            "fast_assembly": false,
                            "cinema_mode": false
                        }
                    ],
                    "sfx": []
                },
                {
                    "_uId": "s4u0l7dwp3",
                    "title": "Mano en el Hombro",
                    "text": "Carlos puso su mano callosa sobre el hombro de su hijo. El contacto fue cálido, una bendición grabada en el [PHO:adené|ADN:h] de su gente.",
                    "pause": 0.5,
                    "subtitle": "",
                    "voice": null,
                    "audio": null,
                    "pitch": null,
                    "assets": [
                        {
                            "id": "/media/assets/ethan_pide_bendicion.png",
                            "type": "image",
                            "zoom": "1.2:1.4",
                            "move": "HOR:50:50",
                            "overlay": null,
                            "fit": false,
                            "video_volume": null,
                            "shake": false,
                            "shake_intensity": 5,
                            "rotate": null,
                            "w_rotate": null,
                            "fast_assembly": false,
                            "cinema_mode": false
                        }
                    ],
                    "sfx": []
                },
                {
                    "_uId": "slkvnww5pv",
                    "title": "La Única Verdad",
                    "text": "—Dios me lo bendiga y me lo haga un hombre de bien, mijo. Y nunca lo olvide: el conocimiento es la clave de todo, y en este mundo, la única verdad está en los datos. Aprenda a leerlos y nunca estará perdido.",
                    "pause": 0.5,
